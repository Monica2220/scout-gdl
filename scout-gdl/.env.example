# ── Copia este archivo como .env y llena tus claves ──────────────────────────
# NUNCA subas .env a GitHub. Ya está en .gitignore.

# ── OBLIGATORIA ───────────────────────────────────────────────────────────────
# Obtén tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── FUENTES DE DATOS (opcionales pero recomendadas) ───────────────────────────
# NewsAPI — gratis en https://newsapi.org (100 req/día)
NEWSAPI_KEY=

# Google Places — gratis con $200 USD/mes de crédito
# https://console.cloud.google.com → activa "Places API"
GOOGLE_PLACES_KEY=

# Apollo.io — datos de LinkedIn (50 créditos gratis/mes)
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# ── WHATSAPP — Twilio ─────────────────────────────────────────────────────────
# Regístrate gratis en https://www.twilio.com
# En el sandbox de WhatsApp: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Tu número de WhatsApp con código de país (sin espacios)
TU_WHATSAPP=whatsapp:+523311234567

# ── EMAIL — elige UNA opción ──────────────────────────────────────────────────
# Tu email donde quieres recibir el reporte
EMAIL_DESTINO=tu@email.com

# Opción A: Resend (recomendado — 100 emails/día gratis)
# Regístrate en https://resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_REMITENTE=scout@tudominio.com

# Opción B: Gmail SMTP (si no tienes dominio propio)
# Crea un App Password en: https://myaccount.google.com/apppasswords
# (requiere tener verificación en 2 pasos activada)
GMAIL_USER=tu@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
